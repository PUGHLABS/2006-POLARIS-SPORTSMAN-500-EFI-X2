  "referenceNotes": [
    { "id": "rn-fg-plugs", "text": "Front gearcase drain/fill plugs: 8 mm hex (Allen) socket." },
    { "id": "rn-engine-oil", "text": "Engine oil: Polaris Premium 4 Synthetic 0W-40 - 2 qt (1.9 L) with crankcase sump drained; ~1.75 qt if sump not drained." },
    { "id": "rn-engine-oil-torque", "text": "Engine oil drain plugs: oil-tank plug 14-17 ft-lb (19-23 Nm); crankcase sump plug 14 ft-lb (19 Nm)." },
    { "id": "rn-oil-filter", "text": "Oil filter: hand-tighten 1/2 to 3/4 turn after gasket contacts engine; lube new gasket with fresh oil first." },
    { "id": "rn-tank-screen", "text": "Oil-tank screen fitting: seal threads with Loctite PST 505 or PTFE tape; rotate clockwise minimum 2.5 turns until nipple aligns with tank mark; max torque 25 ft-lb (34 Nm)." },
    { "id": "rn-oil-prime", "text": "Oil-pump prime: required any time the hose between oil tank and pump inlet is disconnected - clamp vent line 2 in from tank, run engine 10-20 sec, release clamp, listen for rush of air (FSM p74)." },
    { "id": "rn-trans-oil", "text": "Transmission oil: Polaris Premium AGL Synthetic Gearcase Lubricant - 32 oz (948 mL); fill & drain plugs both 22 ft-lb (30 Nm)." },
    { "id": "rn-trans-fill", "text": "Transmission fill plug location: left side, under rear fender, behind wheel." },
    { "id": "rn-trans-drain", "text": "Transmission drain plug location: right side of gearcase, behind wheel well." },
    { "id": "rn-fg-oil", "text": "Front gearcase oil: Polaris Premium Demand Drive Hub Fluid - 5 oz (150 mL); fill plug 8-10 ft-lb (11-14 Nm); drain plug 11 ft-lb (15 Nm)." },
    { "id": "rn-grease", "text": "General lube grease: Polaris Premium All Season Grease, or NLGI No. 2 equivalent (Conoco Superlube M, Mobilegrease Special)." },
    { "id": "rn-ujoint", "text": "Front prop shaft yoke / U-joints: Polaris Premium U-Joint Lube every 500 mi, before storage, after pressure washing or submersion." },
    { "id": "rn-zerks", "text": "Grease zerks: 3 pumps maximum per fitting." },
    { "id": "rn-pn-ref", "text": "Polaris part numbers: see FSM p107." }
  ],
